# Copy to .env.local and fill in.

# From your Neon project's "Connect" panel.
DATABASE_URL=

# Random signing secret for magic-link and session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

# From resend.com — needed to actually send magic-link emails.
RESEND_API_KEY=

# Sender address. Use "onboarding@resend.dev" until a custom domain is verified in Resend.
EMAIL_FROM=PaddockBoard <onboarding@resend.dev>

# Base URL used to build links in emails (e.g. the magic-link callback).
APP_URL=http://localhost:3000

# Used by db/migrate.ts and drizzle.config.ts (drizzle-kit generate/push).
# Copy to .env and fill in from your Neon project's "Connect" panel.
DATABASE_URL=

# Used by db/seed/blue-ridge-kart-club.ts (npm run db:seed). The demo club
# is created under this account so it shows up in that user's /admin view.
SEED_OWNER_EMAIL=
